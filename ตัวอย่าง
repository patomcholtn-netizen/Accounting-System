    <button id='del-cb' class='btn btn-danger' disabled onclick='delCo(${id},this.dataset.nm);closeMo()' data-nm='${name}' style='opacity:.5'>🗑️ ลบถาวร</button></div>`;
  showMo(html);
  setTimeout(function() {
    const inp = document.getElementById('del-ci');
    const btn = document.getElementById('del-cb');
    if (inp && btn) {
      inp.oninput = function() { 
        const ok = inp.value === 'ลบ'; 
        btn.disabled = !ok; 
        btn.style.opacity = ok ? '1' : '.5'; 
      };
      inp.focus();
    }
  }, 100);
}

// ✅ เปลี่ยนจาก "DELETE FROM " + t + " WHERE co_id=?" และ "🗑️ ลบ " + name + " แล้ว"
function delCo(id, name) {
  ["jl","jh","accounts","fixed_assets","asset_categories","periods","contacts","ar_ap",
   "inventory","stock_moves","vat_entries","wht_entries","cheques","tasks","audit_log",
   "oil_types","oil_moves","je_templates"].forEach(function(t) {
    try { db.run(`DELETE FROM ${t} WHERE co_id=?`, [id]); } catch(e) {}
  });
  db.run("DELETE FROM companies WHERE id=?", [id]);
  toast(`🗑️ ลบ ${name} แล้ว`, "ok");
  renderHomepage();
}

