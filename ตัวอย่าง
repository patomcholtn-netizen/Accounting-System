// SPOTLIGHT ⌘K (REFACTORED)
// ════════════════════════════════════════════
let spI = 0, spR = [];

function openSP() {
  if (document.getElementById('sp-bg')) return;
  const bg = document.createElement('div'); 
  bg.id = 'sp-bg';
  bg.innerHTML = `<div id="spotlight">
    <div style="display:flex;align-items:center;gap:9px;padding:13px 15px;border-bottom:1px solid var(--line)">
      <span style="color:var(--ink3)">⌕</span>
      <input id="sp-i" style="background:none;border:none;outline:none;color:var(--ink);font-size:16px;font-family:var(--font);flex:1" placeholder="พิมพ์ชื่อหรือรหัสบริษัท..." autocomplete="off">
      <kbd>Esc</kbd>
    </div>
    <div id="sp-body" style="max-height:340px;overflow-y:auto"></div>
    <div style="padding:7px 13px;border-top:1px solid var(--line);display:flex;gap:10px">
      <span style="font-size:11px;color:var(--ink3);display:flex;align-items:center;gap:4px"><kbd>↑↓</kbd>เลือก</span>
      <span style="font-size:11px;color:var(--ink3);display:flex;align-items:center;gap:4px"><kbd>Enter</kbd>เปิด</span>
    </div>
  </div>`;
  bg.onclick = e => { if (e.target === bg) closeSP(); };
  document.body.appendChild(bg);
  const inp = document.getElementById('sp-i'); 
  inp.focus();
  inp.oninput = () => renderSP(inp.value);
  inp.onkeydown = e => {
    if (e.key === 'Escape') closeSP();
    if (e.key === 'ArrowDown') { e.preventDefault(); spI = Math.min(spI + 1, spR.length - 1); hilSP(); }
    if (e.key === 'ArrowUp') { e.preventDefault(); spI = Math.max(spI - 1, 0); hilSP(); }
    if (e.key === 'Enter') { e.preventDefault(); if (spR[spI]) { openCompany(spR[spI][0]); closeSP(); } }
  };
  renderSP('');
}

// ✅ เปลี่ยนจาก 'background-image:url(' + av + ')' และ 'background:' + color + '20'
function renderSP(q_) {
  const cos = q('SELECT id,code,name,color,av FROM companies ORDER BY code');
  const low = q_.toLowerCase();
  spR = cos.filter(([, cd, nm]) => !low || nm.toLowerCase().includes(low) || cd.toLowerCase().includes(low));
  spI = 0;
  const bd = document.getElementById('sp-body'); 
  if (!bd) return;
  if (!spR.length) { 
    bd.innerHTML = '<div style="text-align:center;padding:22px;color:var(--ink3);font-size:13px">ไม่พบบริษัท</div>'; 
    return; 
  }
  bd.innerHTML = (q_ ? '' : '<div style="font-size:10px;font-weight:700;color:var(--ink3);padding:7px 15px 3px;letter-spacing:.7px;text-transform:uppercase">บริษัท</div>') +
    spR.slice(0, 12).map(([id, cd, nm, color, av], i) => {
      const { ov, pd } = taskStats(id);
      return `<div class="sp-row ${i === 0 ? 'hi' : ''}" id="sri-${i}" onclick="openCompany(${id});closeSP()">
        <div class="sp-av" style="${av.startsWith('data:') ? `background-image:url(${av});background-size:cover;background-position:center` : `background:${color}20;border:1px solid ${color}40`}">${av.startsWith('data:') ? '' : av}</div>
        <div><div style="font-size:13px;font-weight:600;color:var(--ink)">${nm}</div><div style="font-size:11px;color:var(--ink3)">${cd}</div></div>
        <div style="margin-left:auto;display:flex;align-items:center;gap:5px">
          ${ov > 0 ? `<span class="bx br">⚠${ov}</span>` : pd > 0 ? `<span class="bx ba">◷${pd}</span>` : ''}
          <span style="font-size:11px;color:var(--ink3)">฿${fmtK(coRev(id))}</span>
        </div>
      </div>`;
    }).join('');
}

// ✅ เปลี่ยนจาก 'sri-'+(spI)+''
function hilSP() { 
  document.querySelectorAll('.sp-row').forEach((el, i) => el.classList.toggle('hi', i === spI)); 
  document.getElementById(`sri-${spI}`)?.scrollIntoView({ block: 'nearest' }); 
}

function closeSP() { 
  document.getElementById('sp-bg')?.remove(); 
}

