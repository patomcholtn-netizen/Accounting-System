async function initDB() {
  window.SQL = window.SQL||null;
  const SQL = await initSqlJs();

  const savedDb = localStorage.getItem('firmos_db');
  if (savedDb) {
    window.SQL=SQL;
    db = new SQL.Database(new Uint8Array(JSON.parse(savedDb)));
    try { db.run("CREATE TABLE IF NOT EXISTS je_templates(id INTEGER PRIMARY KEY AUTOINCREMENT,co_id INTEGER,name TEXT NOT NULL,desc_text TEXT,lines_json TEXT NOT NULL,created_at TEXT DEFAULT(datetime('now')))"); } catch(e) {}
  } else {
    window.SQL=SQL;
    db = new SQL.Database(); 
    db.run(SCHEMA);
    SAMPLE.forEach((s, i) => {
      const c = COLORS[i % COLORS.length], av = AVTS[i % AVTS.length];
      db.run('INSERT OR IGNORE INTO companies(code,name,type,tax,color,av)VALUES(?,?,?,?,?,?)', [s.c, s.n, s.t, s.tx, c, av]);
      const id = q1('SELECT id FROM companies WHERE code=?', [s.c]);
      if (id) {
        defCOA(id); defAssetCats(id); seedJournals(id, s.c); seedAssets(id); seedPeriods(id); seedTasks(id);
        seedContacts(id); seedInventory(id); seedTax(id); seedCheques(id); seedOil(id);
      }
    });
    db.run(`INSERT OR IGNORE INTO users(username,display_name,role)VALUES('Admin','ผู้ดูแลระบบ','Admin')`);
  }

  renderHomepage();
  renderHomepage();
  startAutoBackup();
}

