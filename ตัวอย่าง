      outline: 1px solid var(--line);
    }
    .btn:hover { transform: translateY(-1px); box-shadow: 0 5px 0 var(--btn-depth-ghost), 0 7px 10px rgba(100,60,20,.18); }
    .btn:active { transform: translateY(3px) !important; box-shadow: 0 1px 0 var(--btn-depth-ghost), 0 1px 3px rgba(100,60,20,.1) !important; }
    .btn-p { background: linear-gradient(180deg,#e8a870 0%,var(--brand) 100%); color:#fff; outline:none; box-shadow:0 4px 0 var(--btn-depth-brand),0 5px 7px rgba(139,74,40,.3); text-shadow:0 1px 2px rgba(0,0,0,.25); }
    .btn-p:hover { box-shadow:0 5px 0 var(--btn-depth-brand),0 7px 12px rgba(139,74,40,.35); }
    .btn-p:active { box-shadow:0 1px 0 var(--btn-depth-brand),0 1px 3px rgba(139,74,40,.2)!important; }
    .btn-g { background:linear-gradient(180deg,#7ec87a 0%,var(--green) 100%); color:#fff; outline:none; box-shadow:0 4px 0 var(--btn-depth-green),0 5px 7px rgba(45,107,40,.3); text-shadow:0 1px 2px rgba(0,0,0,.2); }
    .btn-g:hover { box-shadow:0 5px 0 var(--btn-depth-green),0 7px 12px rgba(45,107,40,.35); }
    .btn-danger { background:linear-gradient(180deg,#e87878 0%,var(--red) 100%); color:#fff; outline:none; box-shadow:0 4px 0 var(--btn-depth-red),0 5px 7px rgba(139,40,40,.3); text-shadow:0 1px 2px rgba(0,0,0,.2); }
    .btn-danger:hover { box-shadow:0 5px 0 var(--btn-depth-red),0 7px 12px rgba(139,40,40,.35); }
    .btn-sm { padding:5px 11px; font-size:11.5px; border-radius:7px; }
    .btn-sm.btn-p { box-shadow:0 3px 0 var(--btn-depth-brand),0 4px 6px rgba(139,74,40,.25); }
    .btn-sm.btn-g { box-shadow:0 3px 0 var(--btn-depth-green),0 4px 6px rgba(45,107,40,.25); }
    .btn-sm.btn-danger { box-shadow:0 3px 0 var(--btn-depth-red),0 4px 6px rgba(139,40,40,.25); }
    .btn-icon { padding:6px 9px; font-size:14px; border-radius:8px; }

    /* ══ MODAL ══════════════════════════════════ */
    .mo-bg {
      position: fixed; inset: 0; z-index: 2000;
