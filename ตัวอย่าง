// ── Real-time totals & balance indicator (REFACTORED) ──────────────
function updJT2() {
  jeL.forEach((l, i) => {
    const de = document.getElementById(`jde-${i}`); if (de) l.d = de.value;
    const dr = document.getElementById(`jdr-${i}`); if (dr) l.dr = dr.value;
    const cr = document.getElementById(`jcr-${i}`); if (cr) l.cr = cr.value;
  });

  let sumDr = 0, sumCr = 0;
  jeL.forEach(l => { sumDr += parseFloat(l.dr) || 0; sumCr += parseFloat(l.cr) || 0; });

  const drEl = document.getElementById('jttdr');
  const crEl = document.getElementById('jttcr');
  const balEl = document.getElementById('jbal');
  const diffWrap = document.getElementById('je-diff-wrap');
  const diffTxt = document.getElementById('je-diff-txt');
  const diffFill = document.getElementById('je-diff-fill');

  // ✅ เปลี่ยนจาก '฿' + sumDr.toLocaleString(...)
  if (drEl) drEl.textContent = `฿${sumDr.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  if (crEl) crEl.textContent = `฿${sumCr.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

  const diff = Math.abs(sumDr - sumCr);
  const balanced = diff < 0.01 && sumDr > 0;

  if (balEl) {
    if (balanced) {
      balEl.className = 'je-bal ok'; 
      balEl.textContent = '✅ สมดุล บันทึกได้';
    } else if (sumDr > 0 || sumCr > 0) {
      balEl.className = 'je-bal diff'; 
      // ✅ เปลี่ยนจาก 'ส่วนต่าง ฿'+(diff.toFixed(2))+''
      balEl.textContent = `ส่วนต่าง ฿${diff.toFixed(2)}`;
    } else {
      balEl.className = 'je-bal err'; 
      balEl.textContent = '⚠ กรุณากรอกข้อมูล';
    }
  }
  
  if (diffWrap) {
    const total = Math.max(sumDr, sumCr);
    if (diff > 0 && total > 0) {
      diffWrap.style.display = 'block';
      if (diffTxt) diffTxt.textContent = fmt(diff);
      if (diffFill) diffFill.style.width = `${Math.min((diff / total) * 100, 100)}%`;
    } else {
      diffWrap.style.display = 'none';
    }
  }

  const saveBtn = document.getElementById('je-save-btn');
  if (saveBtn) saveBtn.style.opacity = balanced ? '1' : '0.6';
}

// ── Save to DB (REFACTORED) ────────────────────────────────────────
function saveJE() {
  jeL.forEach((l, i) => {
    const de = document.getElementById(`jde-${i}`); if (de) l.d = de.value;
    const dr = document.getElementById(`jdr-${i}`); if (dr) l.dr = dr.value;
    const cr = document.getElementById(`jcr-${i}`); if (cr) l.cr = cr.value;
  });
  closeAcDrop();
  document.removeEventListener('mousedown', _jeOutsideClick, true);

  const ls = jeL.filter(l => l.a && (parseFloat(l.dr) > 0 || parseFloat(l.cr) > 0));
  if (ls.length < 2) return toast('ต้องมีอย่างน้อย 2 บรรทัดที่เลือกบัญชีและกรอกจำนวน', 'er');

  let dr = 0, cr = 0;
  ls.forEach(l => { dr += parseFloat(l.dr) || 0; cr += parseFloat(l.cr) || 0; });
  
  // ✅ เปลี่ยนจาก 'Dr ('+(fmt(dr))+') ≠ Cr ('+(fmt(cr))+') — ไม่สามารถบันทึกได้'
  if (Math.abs(dr - cr) > 0.01) return toast(`Dr (${fmt(dr)}) ≠ Cr (${fmt(cr)}) — ไม่สามารถบันทึกได้`, 'er');

  let doc = (document.getElementById('jd').value || '').trim();
  if (!doc) doc = genDoc(acId);
  const dt = document.getElementById('jdt').value;
  if (!dt) return toast('กรุณาระบุวันที่', 'er');
  const dupDoc = q1('SELECT COUNT(*) FROM jh WHERE doc=? AND co_id=?', [doc, acId]);
  // ✅ เปลี่ยนจาก 'เลขที่ "'+(doc)+'" ซ้ำ'
  if (dupDoc > 0) return toast(`เลขที่ "${doc}" ซ้ำ`, 'er');
  
  const mon = parseInt(dt.split('-')[1]), yr = parseInt(dt.split('-')[0]);
  const lck = checkLock(yr, mon);
  if (!lck.ok) return toast(lck.msg, 'er');

  try {
    db.run('BEGIN');
    db.run("INSERT INTO jh(doc,co_id,dt,dty,ref,desc,mon,yr,status)VALUES(?,?,?,?,?,?,?,?,'Posted')",
      [doc, acId, dt,
        document.getElementById('jty').value,
        document.getElementById('jrf').value || null,
        document.getElementById('jds').value || '',
        mon, yr]);
    ls.forEach((l, i) =>
      db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,?,?,?,?,?)',
        [doc, acId, i + 1, l.a, l.d || '', parseFloat(l.dr) || 0, parseFloat(l.cr) || 0])
    );
    db.run('COMMIT');
    logAudit('CREATE', 'jh', doc, null, document.getElementById('jds')?.value || doc);
    _jeHistory = [];
    // ✅ เปลี่ยนจาก 'บันทึก '+(doc)+' ✅'
    toast(`บันทึก ${doc} ✅`, 'ok');
    wsTab('journal', null);
  } catch (e) {
    try { db.run('ROLLBACK'); } catch (_) { }
    toast(e.message, 'er');
  }
}

