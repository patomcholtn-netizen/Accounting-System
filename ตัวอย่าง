function buildSheetVAT() {
  const { nm, BE } = getBaseInfo();
  const thMonths = ['', 'ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.'];
  const vatByMonth = {};
  for (let m = 1; m <= 12; m++) vatByMonth[m] = { base: 0, vat: 0 };

  const vatRecs = q('SELECT * FROM vat_records WHERE co_id=? ORDER BY doc_date', [acId]);
  vatRecs.filter(r => r[2] === 'Output').forEach(r => {
    const mon = parseInt((r[5] || '').split('-')[1]) || 0;
    if (mon >= 1 && mon <= 12) { vatByMonth[mon].base += parseFloat(r[7]) || 0; vatByMonth[mon].vat += parseFloat(r[9]) || 0; }
  });

  const totalInputVAT = vatRecs.filter(r => r[2] === 'Input').reduce((s, r) => s + (parseFloat(r[9]) || 0), 0);
  const vatDataRows = [];
  for (let m = 1; m <= 12; m++) {
    vatDataRows.push([`${thMonths[m]} ${BE}`, 'ภาษีขาย', '', nm, vatByMonth[m].base, 7, vatByMonth[m].vat]);
  }

  const aoa = [
    [nm, '', '', '', '', '', ''],
    [`รายงานภาษีมูลค่าเพิ่ม ปี ${BE}`, '', '', '', '', '', ''],
