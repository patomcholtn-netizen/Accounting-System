function addJL() {
  _jeHistory.push(JSON.parse(JSON.stringify(jeL)));
  jeL.push({ a: '', d: '', dr: '', cr: '' });
  rJLRow2(jeL.length - 1);
  updJT2();
  setTimeout(() => document.getElementById(`jac-${jeL.length - 1}`)?.focus(), 20);
}

function _delRow(i) {
  if (jeL.length <= 2) return toast('ต้องมีอย่างน้อย 2 บรรทัด', 'wa');
  _jeHistory.push(JSON.parse(JSON.stringify(jeL)));
  closeAcDrop();
  jeL.splice(i, 1);
  _rebuildGrid();
}

function _delFocusedRow() {
  const active = document.querySelector('.jg tbody tr.je-active');
  if (!active) return;
  const rows = [...document.querySelectorAll('.jg tbody tr')];
  const idx = rows.indexOf(active);
  if (idx >= 0) _delRow(idx);
}

function _rebuildGrid() {
  const tb = document.getElementById('jtb');
  if (!tb) return;
  tb.innerHTML = '';
  jeL.forEach((_, i) => rJLRow2(i));
  updJT2();
}

