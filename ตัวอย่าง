// ── Render a single row (REFACTORED) ───────────────────────────────
function rJLRow2(i) {
  // ✅ เปลี่ยนจาก 'jlr-'+(i)+'' เป็น template literal
  let tr = document.getElementById(`jlr-${i}`);
  const tb = document.getElementById('jtb');
  if (!tb) return;
  if (!tr) { 
    tr = document.createElement('tr'); 
    tr.id = `jlr-${i}`; 
    tb.appendChild(tr); 
  }

  const l = jeL[i];
  // ✅ เปลี่ยนจาก ''+(l.a)+' — '+(_acList.find(a => a.aid === l.a)?.name || l.a)+'' เป็น template literal
  const dispVal = l.a ? `${l.a} — ${_acList.find(a => a.aid === l.a)?.name || l.a}` : '';
  const hasVal = l.a ? ' has-val' : '';

  tr.innerHTML = `
    <td class="je-rn">${i + 1}</td>
    <td style="padding:0">
      <input id="jac-${i}" class="jg-acc${hasVal}" value="${dispVal}"
        placeholder="รหัสหรือชื่อบัญชี..."
        data-aid="${l.a || ''}" autocomplete="off" spellcheck="false"
        oninput="_onAccInp(event,${i})"
        onkeydown="_onAccKey(event,${i})"
        onfocus="_onAccFocus(event,${i})"
        onblur="_onAccBlur(event,${i})"
      >
    </td>
    <td><input id="jde-${i}" placeholder="คำอธิบาย" value="${l.d || ''}"
        oninput="jeL[${i}].d=this.value"
        onkeydown="_jeln(event,${i},'d')"></td>
    <td><input id="jdr-${i}" type="number" min="0" step="0.01" class="num" placeholder="0.00"
        value="${l.dr || ''}"
        oninput="_onNum(event,${i},'dr')"
        onkeydown="_jeln(event,${i},'dr')"
        onblur="_fmtOnBlur(event)"></td>
    <td><input id="jcr-${i}" type="number" min="0" step="0.01" class="num" placeholder="0.00"
        value="${l.cr || ''}"
        oninput="_onNum(event,${i},'cr')"
        onkeydown="_jeln(event,${i},'cr')"
        onblur="_fmtOnBlur(event)"></td>
    <td style="text-align:center">
      <button onclick="_delRow(${i})"
        style="background:none;border:none;color:var(--ink3);cursor:pointer;font-size:13px;padding:4px 6px;border-radius:4px;transition:all .1s"
        onmouseover="this.style.color='var(--red)';this.style.background='var(--rdim)'"
        onmouseout="this.style.color='var(--ink3)';this.style.background='none'"
        title="ลบบรรทัด (Alt+D)">✕</button>
    </td>
  `;
  
  // Highlight active row on focus
  tr.querySelectorAll('input').forEach(inp => {
    inp.addEventListener('focus', () => {
      document.querySelectorAll('.jg tbody tr').forEach(r => r.classList.remove('je-active'));
      tr.classList.add('je-active');
    });
  });
}

// ── Account input handlers (REFACTORED) ────────────────────────────
function _onAccInp(e, i) {
  const v = e.target.value;
  e.target.classList.remove('has-val', 'acc-err');
  jeL[i].a = '';
  openAcDrop(i, v);
}

function _onAccKey(e, i) {
  if (_acDrop && _acDropRow === i) {
    const res = _acDrop._results || [];
    if (e.key === 'ArrowDown') { e.preventDefault(); _acDropHi = Math.min(_acDropHi + 1, res.length - 1); hilDrop(); return; }
    if (e.key === 'ArrowUp') { e.preventDefault(); _acDropHi = Math.max(_acDropHi - 1, 0); hilDrop(); return; }
    if (e.key === 'Enter' || e.key === 'Tab') {
      e.preventDefault();
      if (res[_acDropHi]) { pickAcc(i, res[_acDropHi].aid, res[_acDropHi].name); return; }
    }
    if (e.key === 'Escape') { closeAcDrop(); return; }
  }
  // ✅ เปลี่ยนจาก 'jde-'+(i)+'' เป็น template literal
  if ((e.key === 'Enter' || e.key === 'Tab') && !e.shiftKey && !_acDrop) {
    e.preventDefault();
    document.getElementById(`jde-${i}`)?.focus();
  }
}

function _onAccFocus(e, i) {
  const v = e.target.value;
  if (!jeL[i].a) openAcDrop(i, v);
}

function _onAccBlur(e, i) {
  setTimeout(() => {
    if (_acDrop) return;
    // ✅ เปลี่ยนจาก 'jac-'+(i)+'' เป็น template literal
    const inp = document.getElementById(`jac-${i}`);
    if (!inp) return;
    const v = inp.value.trim();
    if (!v) { jeL[i].a = ''; return; }
    if (!jeL[i].a) {
      const exact = _acList.find(a => a.aid === v || a.aid === v.split(' ')[0]);
      if (exact) { pickAcc(i, exact.aid, exact.name); }
      else { inp.classList.add('acc-err'); inp.title = 'ไม่พบบัญชี — กรุณาพิมพ์ใหม่'; }
    }
  }, 200);
}

// ── Desc / Dr / Cr handlers (REFACTORED) ───────────────────────────
function _onNum(e, i, field) {
  const v = e.target.value;
  jeL[i][field] = v;
  // ✅ เปลี่ยนจาก 'jcr-'+(i)+'' และ 'jdr-'+(i)+'' เป็น template literal
  if (field === 'dr' && parseFloat(v) > 0) {
    jeL[i].cr = '';
    const crEl = document.getElementById(`jcr-${i}`); 
    if (crEl) crEl.value = '';
  }
  if (field === 'cr' && parseFloat(v) > 0) {
    jeL[i].dr = '';
    const drEl = document.getElementById(`jdr-${i}`); 
    if (drEl) drEl.value = '';
  }
  updJT2();
}

function _fmtOnBlur(e) {
  const v = parseFloat(e.target.value);
  if (!isNaN(v) && v > 0) e.target.value = v.toFixed(2);
  else if (e.target.value === '0' || e.target.value === '') e.target.value = '';
}

// ── Row navigation (REFACTORED) ────────────────────────────────────
function _jeln(e, i, field) {
  if (e.key !== 'Enter' && !(e.key === 'Tab' && !e.shiftKey)) return;
  e.preventDefault();
  const order = ['d', 'dr', 'cr'];
  // ✅ เปลี่ยนจาก 'jde-'+(i)+'' เป็น template literal
  const ids = { 
    d: `jde-${i}`, 
    dr: `jdr-${i}`, 
    cr: `jcr-${i}` 
  };
  const idx = order.indexOf(field);
  if (idx < order.length - 1) {
    document.getElementById(ids[order[idx + 1]])?.focus();
  } else {
    // ✅ เปลี่ยนจาก 'jac-'+(i + 1)+'' เป็น template literal
    if (i < jeL.length - 1) {
      document.getElementById(`jac-${i + 1}`)?.focus();
    } else {
      addJL();
    }
  }
}

// ── Header row navigation ─────────────────────────────────────────
function jnh2(e, id) {
  if (e.key !== 'Enter') return;
  e.preventDefault();
  const order = ['jdt', 'jty', 'jrf', 'jds'];
  const idx = order.indexOf(id);
  if (idx < order.length - 1) document.getElementById(order[idx + 1])?.focus();
  else document.getElementById('jac-0')?.focus();
}

