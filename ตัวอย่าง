function runFME() {
  const { yr, mon } = getMEI(), el = document.getElementById('me-res');
  const steps = [];
  // ✅ เปลี่ยนจาก 'ค่าเสื่อม: '+(r1.message)+''
  const r1 = runDeprEngine(yr, mon); 
  steps.push({ ok: r1.success, msg: `ค่าเสื่อม: ${r1.message}` });
  // ✅ เปลี่ยนจาก 'VAT: '+(r2.message)+''
  const r2 = runVATClearing(yr, mon); 
  steps.push({ ok: r2.success || r2.message?.includes('ไม่มี'), msg: `VAT: ${r2.message}` });
  const lck = checkLock(yr, mon);
  if (lck.ok) { 
    db.run('UPDATE periods SET status=\'Closed\',closed_at=datetime(\'now\') WHERE co_id=? AND yr=? AND mon=?', [acId, yr, mon]); 
    // ✅ เปลี่ยนจาก 'ล็อค '+(thM(mon))+' '+(yr)+' สำเร็จ'
    steps.push({ ok: true, msg: `ล็อค ${thM(mon)} ${yr} สำเร็จ` }); 
  } else {
    steps.push({ ok: false, msg: lck.msg });
  }
  
  if (el) {
    // ✅ เปลี่ยนจาก '<div class="al '+(s.ok ? 'al-g' : 'al-a')+'" ...>'
    el.innerHTML = steps.map(s => 
      `<div class="al ${s.ok ? 'al-g' : 'al-a'}" style="margin-bottom:5px;padding:7px 11px">
        <span>${s.ok ? '✅' : '⚠️'}</span>
        <span style="font-size:12px">${s.msg}</span>
      </div>`
    ).join('');
  }
  rMonthEnd();
}

