function loadDbFromFile(event) {
  const file = event.target.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function (e) {
    try {
      const Uints = new Uint8Array(e.target.result);

      const magic = [83, 81, 76, 105, 116, 101, 32, 102, 111, 114, 109, 97, 116, 32, 51];
      let isSQLite = true;
      for (let i = 0; i < magic.length; i++) {
        if (Uints[i] !== magic[i]) isSQLite = false;
      }

      if (!isSQLite) {
        toast('❌ ไฟล์ไม่ถูกต้อง! กรุณาเลือกไฟล์ .sqlite ของระบบ', 'er');
        event.target.value = '';
        return;
      }

      localStorage.setItem('firmos_db', JSON.stringify(Array.from(Uints)));
      localStorage.setItem('firmos_blank', '0');

      toast('📂 โหลดไฟล์สำเร็จ กำลังรีสตาร์ทระบบ...', 'ok');
      setTimeout(() => {
        window.location.reload();
      }, 1000);

    } catch (err) {
      toast('❌ เกิดข้อผิดพลาดในการอ่านไฟล์', 'er');
    }
  };

  event.target.value = '';
  reader.readAsArrayBuffer(file);
}




