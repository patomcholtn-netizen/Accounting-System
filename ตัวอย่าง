  const tbData = q('SELECT a.aid, a.name, a.type, COALESCE(SUM(l.dr),0) tdr, COALESCE(SUM(l.cr),0) tcr, CASE WHEN a.norm=\'Debit\' THEN COALESCE(SUM(l.dr),0)-COALESCE(SUM(l.cr),0) ELSE COALESCE(SUM(l.cr),0)-COALESCE(SUM(l.dr),0) END bal FROM accounts a LEFT JOIN jl l ON a.aid=l.aid AND a.co_id=l.co_id LEFT JOIN jh h ON l.doc=h.doc AND l.co_id=h.co_id AND h.status=\'Posted\' WHERE a.co_id=? AND a.hdr=0 GROUP BY a.aid HAVING(tdr>0 OR tcr>0) ORDER BY a.aid', [acId]);

