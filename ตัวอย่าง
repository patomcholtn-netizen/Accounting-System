    .al-g { background: var(--green-bg); border: 1px solid rgba(5,150,105,.15); color: var(--green); }
    .al-r { background: var(--red-bg); border: 1px solid rgba(220,38,38,.15); color: var(--red); }
    .al-a { background: var(--amber-bg); border: 1px solid rgba(217,119,6,.15); color: var(--amber); }

    /* ══ FORM ELEMENTS ══════════════════════════ */
    .fg { display: flex; flex-direction: column; gap: 5px; margin-bottom: 11px; }
    .fg label { font-size: 11px; font-weight: 700; color: var(--ink2); }

    .fg input, .fg select, .fg textarea {
      background: var(--bg1); border: 1px solid var(--line2);
