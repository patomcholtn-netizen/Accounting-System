// ════════════════════════════════════════════
// DEPRECIATION ENGINE (REFACTORED)
// ════════════════════════════════════════════
function runDeprEngine(yr, mon) {
  const lck = checkLock(yr, mon); 
  if (!lck.ok) return { success: false, message: lck.msg };
  
  const assets = q('SELECT fa.*,ac.depr_acct,ac.accum_acct FROM fixed_assets fa JOIN asset_categories ac ON fa.cat_id=ac.id WHERE fa.co_id=? AND fa.status=\'Active\'', [acId]);
  let total = 0, ok = 0, skip = 0;
  
  db.run('BEGIN');
  try {
    assets.forEach(asset => {
      const [id, , code, name, , acqDate, origCost, salvage, life, accumDepr, , deprAcct, accumAcct] = asset;
      if (q1('SELECT COUNT(*) FROM depr_log WHERE co_id=? AND asset_id=? AND yr=? AND mon=?', [acId, id, yr, mon]) > 0) { 
        skip++; 
        return; 
      }
      const rem = (origCost - salvage) - accumDepr;
      if (rem <= 0.01) { 
        db.run('UPDATE fixed_assets SET status=\'FullyDepreciated\' WHERE id=? AND co_id=?', [id, acId]); 
        skip++; 
        return; 
      }
      const acqYM = acqDate.substring(0, 7);
      // ✅ เปลี่ยนจาก ''+(yr)+'-'+(String(mon).padStart(2, '0'))+''
      if (`${yr}-${String(mon).padStart(2, '0')}` < acqYM) { 
        skip++; 
        return; 
      }
      const amt = Math.min(Math.round((origCost - salvage) / life * 100) / 100, rem);
      // ✅ เปลี่ยนจาก 'DEPR-'+(yr)+''+(String(mon).padStart(2, '0'))+'-'+(String(id).padStart(3, '0'))+''
      const docNo = `DEPR-${yr}${String(mon).padStart(2, '0')}-${String(id).padStart(3, '0')}`;
      db.run('INSERT OR IGNORE INTO depr_log(co_id,asset_id,yr,mon,amount,doc_no)VALUES(?,?,?,?,?,?)', [acId, id, yr, mon, amt, docNo]);
      db.run('UPDATE fixed_assets SET accum_depr=accum_depr+? WHERE id=? AND co_id=?', [amt, id, acId]);
      total += amt; 
      ok++;
      // ✅ เปลี่ยนจาก 'DEPR-BATCH-'+(acId)+'-'+(yr)+''+(String(mon).padStart(2, '0'))+''
      const mainDoc = `DEPR-BATCH-${acId}-${yr}${String(mon).padStart(2, '0')}`;
      const lastDay = new Date(yr, mon, 0).toISOString().split('T')[0];
      if (ok === 1) {
        // ✅ เปลี่ยนจาก 'ค่าเสื่อมราคา '+(thM(mon))+' '+(yr)
        db.run('INSERT OR IGNORE INTO jh(doc,co_id,dt,dty,desc,mon,yr,status)VALUES(?,?,?,\'Depreciation\',?, ?,?,\'Posted\')', 
          [mainDoc, acId, lastDay, `ค่าเสื่อมราคา ${thM(mon)} ${yr}`, mon, yr]);
      }
      const seq = q1('SELECT COALESCE(MAX(seq),0)+1 FROM jl WHERE doc=? AND co_id=?', [mainDoc, acId]) || 1;
      // ✅ เปลี่ยนจาก 'ค่าเสื่อม '+?
      db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,?,?,?,?,0)', 
        [mainDoc, acId, seq, deprAcct, `ค่าเสื่อม ${name}`, amt]);
      // ✅ เปลี่ยนจาก 'เสื่อมสะสม '+?
      db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,?,?,?,0,?)', 
        [mainDoc, acId, seq + 1, accumAcct, `เสื่อมสะสม ${name}`, amt]);
    });
    db.run('COMMIT');
    // ✅ เปลี่ยนจาก 'ลงค่าเสื่อม '+(ok)+' รายการ รวม ฿'+(fmt(total))+''
    return { success: true, ok, skip, total, message: `ลงค่าเสื่อม ${ok} รายการ รวม ฿${fmt(total)}` };
  } catch (e) { 
    db.run('ROLLBACK'); 
    return { success: false, message: e.message }; 
  }
}

function runVATClearing(yr, mon) {
  const lck = checkLock(yr, mon); 
  if (!lck.ok) return { success: false, message: lck.msg };
  
  const outVAT = q1('SELECT COALESCE(SUM(cr),0) FROM jl JOIN jh ON jl.doc=jh.doc AND jl.co_id=jh.co_id WHERE jl.aid=\'2201\' AND jh.mon=? AND jh.yr=? AND jl.co_id=?', [mon, yr, acId]) || 0;
  const inVAT = q1('SELECT COALESCE(SUM(dr),0) FROM jl JOIN jh ON jl.doc=jh.doc AND jl.co_id=jh.co_id WHERE jl.aid=\'1202\' AND jh.mon=? AND jh.yr=? AND jl.co_id=?', [mon, yr, acId]) || 0;
  
  if (outVAT === 0 && inVAT === 0) return { success: false, message: 'ไม่มีรายการ VAT ในงวดนี้' };
  
  // ✅ เปลี่ยนจาก 'VAT-'+(acId)+'-'+(yr)+''+(String(mon).padStart(2, '0'))+''
  const docNo = `VAT-${acId}-${yr}${String(mon).padStart(2, '0')}`;
  if (q1('SELECT COUNT(*) FROM jh WHERE doc=? AND co_id=?', [docNo, acId]) > 0) 
    return { success: false, message: 'ปิด VAT งวดนี้ไปแล้ว' };
  
  const net = outVAT - inVAT, lastDay = new Date(yr, mon, 0).toISOString().split('T')[0];
  db.run('BEGIN');
  try {
    // ✅ เปลี่ยนจาก 'ปิด VAT '+(thM(mon))+' '+(yr)
    db.run('INSERT INTO jh(doc,co_id,dt,dty,desc,mon,yr,status)VALUES(?,?,?,\'VATClearing\',?, ?,?,\'Posted\')', 
      [docNo, acId, lastDay, `ปิด VAT ${thM(mon)} ${yr}`, mon, yr]);
    if (outVAT > 0) db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,1,\'2201\',\'ปิดภาษีขาย\',?,0)', [docNo, acId, outVAT]);
    if (inVAT > 0) db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,2,\'1202\',\'ปิดภาษีซื้อ\',0,?)', [docNo, acId, inVAT]);
    if (net > 0) db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,3,\'2202\',\'VAT ต้องนำส่ง\',0,?)', [docNo, acId, net]);
    else if (net < 0) db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,3,\'1203\',\'VAT รอขอคืน\',?,0)', [docNo, acId, Math.abs(net)]);
    db.run('COMMIT');
    // ✅ เปลี่ยนจาก 'Output ฿'+(fmt(outVAT))+' / Input ฿'+(fmt(inVAT))+' / '+(net >= 0 ? 'นำส่ง' : 'ขอคืน')+' ฿'+(fmt(Math.abs(net)))+''
    return { success: true, outVAT, inVAT, net, message: `Output ฿${fmt(outVAT)} / Input ฿${fmt(inVAT)} / ${net >= 0 ? 'นำส่ง' : 'ขอคืน'} ฿${fmt(Math.abs(net))}` };
  } catch (e) { 
    db.run('ROLLBACK'); 
    return { success: false, message: e.message }; 
  }
}

function runYearEnd(yr) {
  const closed = q1('SELECT COUNT(*) FROM periods WHERE co_id=? AND yr=? AND status IN(\'Closed\',\'Locked\')', [acId, yr]) || 0;
  // ✅ เปลี่ยนจาก 'ปิดแล้ว '+(closed)+'/12 งวด — ต้องปิดทุกงวดก่อน'
  if (closed < 3) return { success: false, message: `ปิดแล้ว ${closed}/12 งวด — ต้องปิดทุกงวดก่อน` };
  
  // ✅ เปลี่ยนจาก 'YE-'+(acId)+'-'+(yr)+''
  const doc = `YE-${acId}-${yr}`;
  if (q1('SELECT COUNT(*) FROM jh WHERE doc=? AND co_id=?', [doc, acId]) > 0) 
    // ✅ เปลี่ยนจาก 'ปิดบัญชีปี '+(yr)+' ไปแล้ว'
    return { success: false, message: `ปิดบัญชีปี ${yr} ไปแล้ว` };
  
  const rA = q('SELECT a.aid,a.name,COALESCE(SUM(l.cr),0)-COALESCE(SUM(l.dr),0) AS bal FROM accounts a LEFT JOIN jl l ON a.aid=l.aid AND a.co_id=l.co_id LEFT JOIN jh h ON l.doc=h.doc AND l.co_id=h.co_id AND h.yr=? AND h.status=\'Posted\' WHERE a.type=\'Revenue\' AND a.hdr=0 AND a.co_id=? GROUP BY a.aid HAVING bal<>0', [yr, acId]);
  const eA = q('SELECT a.aid,a.name,COALESCE(SUM(l.dr),0)-COALESCE(SUM(l.cr),0) AS bal FROM accounts a LEFT JOIN jl l ON a.aid=l.aid AND a.co_id=l.co_id LEFT JOIN jh h ON l.doc=h.doc AND l.co_id=h.co_id AND h.yr=? AND h.status=\'Posted\' WHERE a.type=\'Expense\' AND a.hdr=0 AND a.co_id=? GROUP BY a.aid HAVING bal<>0', [yr, acId]);
  
  const tR = rA.reduce((s, r) => s + r[2], 0), tE = eA.reduce((s, r) => s + r[2], 0), net = tR - tE;
  
  db.run('BEGIN');
  try {
    // ✅ เปลี่ยนจาก 'ปิดบัญชีสิ้นปี '+(yr)
    db.run('INSERT INTO jh(doc,co_id,dt,dty,desc,mon,yr,status)VALUES(?,?,?,\'YearEndClose\',?, 12,?,\'Posted\')', 
      [doc, acId, `${yr}-12-31`, `ปิดบัญชีสิ้นปี ${yr}`, yr]);
    let seq = 1;
    // ✅ เปลี่ยนจาก 'ปิด '+?
    rA.forEach(([aid, name, bal]) => db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,?,?,?, ?,0)', 
      [doc, acId, seq++, aid, `ปิด ${name}`, bal]));
    // ✅ เปลี่ยนจาก 'ปิด '+?
    eA.forEach(([aid, name, bal]) => db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,?,?,?, 0,?)', 
      [doc, acId, seq++, aid, `ปิด ${name}`, bal]));
    if (net > 0) db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,?,\'3201\',\'โอนกำไรสุทธิ\',0,?)', [doc, acId, seq, net]);
    else if (net < 0) db.run('INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr)VALUES(?,?,?,\'3201\',\'โอนขาดทุน\',?,0)', [doc, acId, seq, Math.abs(net)]);
    db.run('UPDATE periods SET status=\'Locked\' WHERE co_id=? AND yr=?', [acId, yr]);
    db.run('COMMIT');
    // ✅ เปลี่ยนจาก 'ปิดบัญชีปี '+(yr)+' สำเร็จ! กำไรสุทธิ ฿'+(fmt(net))+' → กำไรสะสม'
    return { success: true, net, message: `ปิดบัญชีปี ${yr} สำเร็จ! กำไรสุทธิ ฿${fmt(net)} → กำไรสะสม` };
  } catch (e) { 
    db.run('ROLLBACK'); 
    return { success: false, message: e.message }; 
  }
}

