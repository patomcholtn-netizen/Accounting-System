  b.innerHTML = `<span style="color:var(--green);font-size:15px">💾</span><span><strong>Backup อัตโนมัติ</strong> — บันทึกแล้ว</span><button onclick="document.getElementById('_bkbanner').remove()" style="background:none;border:none;cursor:pointer;color:var(--ink4);font-size:14px;margin-left:auto">✕</button>`;
  document.body.appendChild(b);
