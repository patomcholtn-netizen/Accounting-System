    .toast-in { background: var(--bg1); border: 1px solid var(--line); color: var(--ink); box-shadow: var(--shadow-lg); }
    @keyframes toastIn { from { transform: translateX(20px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

    /* ══ JOURNAL ENTRY ══════════════════════════ */
    .je-wrap { background: var(--bg1); border: 1px solid var(--line); border-radius: var(--r2); overflow: hidden; }
