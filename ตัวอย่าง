    }
    .search-bar:focus-within { border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); }
    .search-bar input { background: none; border: none; outline: none; color: var(--ink); font-size: 13px; font-family: var(--font); flex: 1; min-width: 0; }
    .search-bar input::placeholder { color: var(--ink3); }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* Print */
    @media print {
      * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
      body, #app, #body-wrap, #main-content, .ws-body { height: auto !important; overflow: visible !important; background: #fff !important; }
      #header, #sidebar, .ws-topbar, .ws-tabs, .btn, #toast-b, .add-co-card { display: none !important; }
      .rpt, .tw { border: none !important; box-shadow: none !important; overflow: visible !important; }
