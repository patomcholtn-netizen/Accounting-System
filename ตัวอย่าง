  const tR = q1('SELECT COALESCE(SUM(l.cr)-SUM(l.dr),0) FROM jl l JOIN jh h ON l.doc=h.doc AND l.co_id=h.co_id WHERE l.aid LIKE \'4%\' AND l.co_id=? AND h.yr=2024', [acId]) || 0;
