    .sp-av { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 13px; }

    /* ══ MISC ═══════════════════════════════════ */
    .empty {
      text-align: center; padding: 36px; color: var(--ink3);
    }
    .empty .ic { font-size: 30px; margin-bottom: 10px; }

    .prog { height: 4px; background: var(--bg3); border-radius: 2px; overflow: hidden; }
    .prog-f { height: 100%; border-radius: 2px; }

    .search-bar {
