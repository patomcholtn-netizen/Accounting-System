// ✅ แก้ไข string concatenation ที่ซับซ้อนมากในฟังก์ชันนี้
function saveOilMove(mtype) {
  const pfx = mtype==='BUY'?'ob':mtype==='SELL'?'os':'oa';
  // ✅ เปลี่ยนจาก ''+(pfx)+'-oil' เป็น template literal
  const oilId = parseInt(document.getElementById(`${pfx}-oil`).value);
  const dt = document.getElementById(`${pfx}-dt`)?.value || today();
  const qty = parseFloat(document.getElementById(`${pfx}-qty`).value) || 0;
  // ✅ เปลี่ยนจาก ''+(pfx)+'-price'||''+(pfx)+'-cost'
  const price = parseFloat(document.getElementById(`${pfx}-price`)?.value || document.getElementById(`${pfx}-cost`)?.value) || 0;
  // ✅ เปลี่ยนจาก ''+(pfx)+'-total'||''+(pfx)+'-total'
  const total = parseFloat(document.getElementById(`${pfx}-total`)?.value) || (qty * price);
  const ref = document.getElementById(`${pfx}-ref`) ? document.getElementById(`${pfx}-ref`).value.trim() : null;
  const sc = document.getElementById(`${pfx}-sc`) ? document.getElementById(`${pfx}-sc`).value.trim() : null;
  const note = document.getElementById(`${pfx}-note`).value.trim();

  if (!oilId) return toast('กรุณาเลือกประเภทน้ำมัน', 'er');
  if (qty === 0) return toast('กรุณากรอกจำนวน', 'er');

  const oil = q('SELECT qty_on_hand,avg_cost FROM oil_types WHERE id=? AND co_id=?',[oilId,acId])[0];
  if (!oil) return toast('ไม่พบประเภทน้ำมัน', 'er');
  let [curQty, curCost] = oil;

  let newQty, newCost;
  if (mtype === 'BUY') {
    if (qty <= 0) return toast('จำนวนซื้อต้องมากกว่า 0', 'er');
    newQty = curQty + qty;
    newCost = newQty > 0 ? ((curQty * curCost) + (qty * price)) / newQty : price;
    db.run('UPDATE oil_types SET qty_on_hand=?,avg_cost=? WHERE id=?',[newQty,newCost,oilId]);
  } else if (mtype === 'SELL') {
    if (qty <= 0) return toast('จำนวนขายต้องมากกว่า 0', 'er');
    // ✅ เปลี่ยนจาก 'สต็อกไม่พอ — คงเหลือ '+(curQty.toFixed(2))+' หน่วย'
    if (qty > curQty) return toast(`สต็อกไม่พอ — คงเหลือ ${curQty.toFixed(2)} หน่วย`, 'er');
    newQty = curQty - qty;
    newCost = curCost;
    db.run('UPDATE oil_types SET qty_on_hand=? WHERE id=?',[newQty,oilId]);
  } else { // ADJ
    newQty = curQty + qty;
    // ✅ เปลี่ยนจาก 'ปรับแล้วสต็อกจะติดลบ ('+(newQty.toFixed(2))+') — ตรวจสอบจำนวน'
    if (newQty < 0) return toast(`ปรับแล้วสต็อกจะติดลบ (${newQty.toFixed(2)}) — ตรวจสอบจำนวน`, 'er');
    newCost = curCost;
    db.run('UPDATE oil_types SET qty_on_hand=? WHERE id=?',[newQty,oilId]);
  }

  const absQty = Math.abs(qty);
  const absTotal = Math.abs(mtype==='ADJ'? absQty*curCost : total||absQty*price);
  db.run('INSERT INTO oil_moves(co_id,oil_type_id,move_date,move_type,qty,unit_price,total_amt,qty_after,ref_doc,supplier_customer,note)VALUES(?,?,?,?,?,?,?,?,?,?,?)',
    [acId,oilId,dt,mtype,absQty,mtype==='ADJ'?curCost:(price||curCost),absTotal,newQty,ref||null,sc||null,note||null]);

  closeMo();
  const typeLabels = {BUY:'ซื้อน้ำมัน',SELL:'ขายน้ำมัน',ADJ:'ปรับสต็อกน้ำมัน'};
  // ✅ เปลี่ยนจาก '✅ บันทึก'+(typeLabels[mtype])+' '+(absQty.toFixed(2))+' หน่วย สำเร็จ'
  toast(`✅ บันทึก${typeLabels[mtype]} ${absQty.toFixed(2)} หน่วย สำเร็จ`, 'ok');
  rOil();
}

