    .bp-ok { background: var(--green-bg); color: var(--green); border: 1px solid rgba(5,150,105,.2); }
    .bp-err { background: var(--red-bg); color: var(--red); border: 1px solid rgba(220,38,38,.2); }

    /* ══ FIXED ASSETS ═══════════════════════════ */
    .dbar { height: 4px; background: var(--bg3); border-radius: 3px; margin-top: 5px; overflow: hidden; }
    .dbar-f { height: 100%; border-radius: 3px; background: var(--brand); }

    /* ══ REPORTS ════════════════════════════════ */
