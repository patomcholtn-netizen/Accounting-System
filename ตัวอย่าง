// ✅ เปลี่ยนจาก 'ข้อมูล ณ วันที่ '+(today())+'' และ 'Aging_'+(nm.replace(/\s/g, '_'))+'_'+(today())+'.xlsx'
function xlsxAging() {
  if (!acId) return;
  const { nm } = getBaseInfo();
  const td = new Date();
  const rows = q(`SELECT a.doc_no, c.name, a.doc_type, a.doc_date, a.due_date, a.amount, a.paid, (a.amount-a.paid) as bal 
              FROM ar_ap a LEFT JOIN contacts c ON a.contact_id=c.id 
              WHERE a.co_id=? AND a.status IN('Open','PartPaid') ORDER BY a.due_date`, [acId]);

  const aoa = [
    [nm, '', '', '', '', '', '', '', '', '', '', ''],
    ['รายงานอายุหนี้ (Aging Report)', '', '', '', '', '', '', '', '', '', '', ''],
    [`ข้อมูล ณ วันที่ ${today()}`, '', '', '', '', '', '', '', '', '', '', ''],
    ['', '', '', '', '', '', '', '', '', '', '', ''],
    ['เลขที่เอกสาร', 'คู่ค้า', 'ประเภท', 'วันที่เอกสาร', 'วันครบกำหนด', 'ยอดรวม', 'ชำระแล้ว', 'ยอดคงเหลือ', 'ยังไม่ถึงกำหนด', '1-30 วัน', '31-60 วัน', '61-90 วัน', '> 90 วัน']
  ];

  rows.forEach(r => {
    const dueDate = new Date(r[4]);
    const days = Math.floor((td - dueDate) / 864e5);
    const bal = parseFloat(r[7]) || 0;

    let bucket = [0, 0, 0, 0, 0];
    if (days > 90) bucket[4] = bal;
    else if (days > 60) bucket[3] = bal;
    else if (days > 30) bucket[2] = bal;
    else if (days > 0) bucket[1] = bal;
    else bucket[0] = bal;

    aoa.push([
      r[0], r[1], r[2], r[3], r[4],
      parseFloat(r[5]) || 0, parseFloat(r[6]) || 0, bal,
      ...bucket
    ]);
  });

  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, makeSheet(aoa, [15, 30, 10, 12, 12, 12, 12, 12, 14, 12, 12, 12, 12]), 'รายงานอายุหนี้');
  if (xlsxDL(wb, `Aging_${nm.replace(/\s/g, '_')}_${today()}.xlsx`)) toast('✅ Export รายงานอายุหนี้ สำเร็จ', 'ok');
}

