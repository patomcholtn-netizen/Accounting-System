    table.jet td { border-bottom: 1px solid var(--line); padding: 0; }
    table.jet td input, table.jet td select { background: none; border: none; outline: none; color: var(--ink); padding: 8px 12px; font-size: 13px; font-family: var(--font); width: 100%; }
    table.jet td input:focus, table.jet td select:focus { background: var(--brand-light); }
