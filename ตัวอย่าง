    .rpt-hd { text-align: center; margin-bottom: 20px; padding-bottom: 14px; border-bottom: 2px solid var(--line); }
    .rpt-co { font-size: 16px; font-weight: 700; color: var(--ink); }
    .rpt-t { font-size: 13px; color: var(--ink3); margin-top: 3px; }
    .rr { display: flex; justify-content: space-between; padding: 6px 0; font-size: 13px; border-bottom: 1px solid var(--line); }
    .rr:last-child { border-bottom: none; }
    .rr.rh { font-weight: 700; font-size: 12px; color: var(--ink3); text-transform: uppercase; letter-spacing: .5px; background: var(--bg2); padding: 7px 10px; border-radius: 4px; margin: 8px 0 4px; }
    .rr.rs { padding-left: 16px; color: var(--ink2); }
    .rr.rtot { font-weight: 700; font-size: 15px; background: var(--bg2); padding: 10px; border-radius: 6px; margin-top: 10px; border: none; }
    .rv { font-family: var(--mono); font-weight: 600; }

    /* ══ SPOTLIGHT ══════════════════════════════ */
    #sp-bg {
      position: fixed; inset: 0; z-index: 3000;
      background: rgba(0,0,0,.5); backdrop-filter: blur(6px);
      display: flex; align-items: flex-start; justify-content: center;
