    <div class="fg"><label>คำอธิบาย</label><input id="eje-ds" value="${h[4]||''}" placeholder="รายละเอียดรายการ"></div>
    <div class="mo-f">
      <button class="btn" onclick="closeMo()">ยกเลิก</button>
      <button class="btn btn-p" onclick="saveEditJE('${doc}')">✅ บันทึก</button>
    </div>`);
  setTimeout(function(){ const el = document.getElementById("eje-dt"); if(el) el.focus(); }, 100);
}

function saveEditJE(doc) {
  const dt = document.getElementById("eje-dt").value;
  if (!dt) return toast("กรุณาระบุวันที่", "er");
  const mon = parseInt(dt.split("-")[1]);
  const yr  = parseInt(dt.split("-")[0]);
  const lck = checkLock(yr, mon);
  if (!lck.ok) return toast(lck.msg, "er");
  db.run("UPDATE jh SET dt=?,dty=?,ref=?,desc=?,mon=?,yr=? WHERE doc=? AND co_id=?",
    [dt, document.getElementById("eje-ty").value, document.getElementById("eje-rf").value||null,
     document.getElementById("eje-ds").value||"", mon, yr, doc, acId]);
  closeMo();
  toast(`✅ แก้ไข ${doc} สำเร็จ`, "ok");
  viewE(doc);
}

