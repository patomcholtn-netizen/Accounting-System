<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FirmOS Pro — ระบบสำนักงานบัญชี</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="sql-asm.js"></script>
  <script src="chart.js"></script>
  <script src="xlsx.js"></script>
  <!-- WASM removed -->
  <style>
    /* ══════════════════════════════════════════════════
       FIRMOS PRO v2 — Design System
       Professional Accounting SaaS
    ══════════════════════════════════════════════════ */
    :root {
      --brand: #c8734a; --brand-dark: #a85a34; --brand-light: #fde8d8; --brand-glow: rgba(200,115,74,.2);
      --bg: #faf6f0; --bg1: #fff8f2; --bg2: #fff3ea; --bg3: #f5e8d8; --bg4: #ead8c0;
      --line: #e8ddd0; --line2: #d4c4b0;
      --ink: #3d2010; --ink2: #5c3d1e; --ink3: #8b6040; --ink4: #c8a882;
      --green: #4fa04a; --green-bg: rgba(79,160,74,.1);
      --red: #c84848; --red-bg: rgba(200,72,72,.1);
      --amber: #c8903a; --amber-bg: rgba(200,144,58,.1);
      --purple: #7c4aed; --purple-bg: rgba(124,74,237,.1);
      --teal: #3a9090; --teal-bg: rgba(58,144,144,.1);
      --sky: #3a7ab0;
      --font: 'IBM Plex Sans Thai', system-ui, sans-serif;
      --mono: 'IBM Plex Mono', ui-monospace, monospace;
      --r: 8px; --r2: 12px; --r3: 16px; --r4: 20px;
      --shadow-xs: 0 1px 2px rgba(100,60,20,.08);
      --shadow: 0 1px 3px rgba(100,60,20,.1), 0 1px 2px rgba(100,60,20,.07);
      --shadow-md: 0 4px 12px rgba(100,60,20,.1), 0 2px 4px rgba(100,60,20,.07);
      --shadow-lg: 0 10px 30px rgba(100,60,20,.12), 0 4px 8px rgba(100,60,20,.08);
      --shadow-xl: 0 20px 60px rgba(100,60,20,.18);
      --sidebar-w: 220px; --sidebar-collapsed-w: 56px;
      --btn-depth-brand: #8b4a28; --btn-depth-green: #2d6b28; --btn-depth-red: #8b2828; --btn-depth-ghost: #c8a882;
    }

    html.dark {
      --bg: #1e140a; --bg1: #261a0e; --bg2: #2e2014; --bg3: #38281a; --bg4: #4a3422;
      --line: #5c3d22; --line2: #7a5030;
      --ink: #f5e8d8; --ink2: #e0c8a8; --ink3: #c8a070; --ink4: #8b6840;
      --brand: #e8a870; --brand-dark: #d08050; --brand-light: rgba(232,168,112,.15); --brand-glow: rgba(232,168,112,.25);
      --green: #7ec87a; --green-bg: rgba(126,200,122,.12);
      --red: #e87878; --red-bg: rgba(232,120,120,.12);
      --amber: #e8b858; --amber-bg: rgba(232,184,88,.12);
      --shadow-xs: 0 1px 2px rgba(0,0,0,.4); --shadow: 0 1px 4px rgba(0,0,0,.4);
      --shadow-md: 0 4px 16px rgba(0,0,0,.4); --shadow-lg: 0 10px 40px rgba(0,0,0,.5); --shadow-xl: 0 20px 60px rgba(0,0,0,.6);
      --btn-depth-brand: #a05828; --btn-depth-green: #3a7830; --btn-depth-red: #983030; --btn-depth-ghost: #7a5030;
    }

    /* RESET */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      height: 100%; overflow: hidden;
      font-family: var(--font); font-size: 14px; line-height: 1.5;
      background: var(--bg); color: var(--ink);
      -webkit-font-smoothing: antialiased;
    }

    /* ══ APP SHELL ══════════════════════════════ */
    #app { height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

    /* ══ TOP HEADER ═════════════════════════════ */
    #header {
      height: 52px; flex-shrink: 0;
      background: linear-gradient(180deg, var(--bg1) 0%, var(--bg2) 100%);
      border-bottom: 2px solid var(--line2);
      display: flex; align-items: center;
      padding: 0 16px 0 20px;
      gap: 12px;
      box-shadow: var(--shadow-xs);
      position: relative; z-index: 100;
    }

    .logo-wrap {
      display: flex; align-items: center; gap: 9px;
      text-decoration: none; flex-shrink: 0;
    }

    .logo-icon {
      width: 30px; height: 30px;
      background: linear-gradient(135deg, var(--brand), var(--brand-dark));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 2px 8px var(--brand-glow);
    }
    .logo-icon svg { width: 16px; height: 16px; fill: #fff; }

    .logo-name {
      font-size: 15px; font-weight: 700;
      color: var(--ink); letter-spacing: -.4px;
      line-height: 1;
    }
    .logo-name em { color: var(--brand); font-style: normal; }

    .logo-version {
      font-size: 9px; font-weight: 600;
      color: var(--brand); background: var(--brand-light);
      padding: 2px 6px; border-radius: 10px;
      letter-spacing: .5px; margin-top: 2px;
    }

    .hdr-div { width: 1px; height: 18px; background: var(--line); flex-shrink: 0; }

    .hdr-breadcrumb {
      font-size: 12.5px; color: var(--ink3); display: flex; align-items: center; gap: 6px;
    }
    .hdr-breadcrumb .sep { color: var(--ink4); }
    .hdr-breadcrumb .active { color: var(--ink2); font-weight: 500; }

    .hdr-spacer { flex: 1; }

    /* Header Buttons */
    .hdr-actions { display: flex; align-items: center; gap: 4px; }

    .hbtn {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 5px 12px; border-radius: 7px; border: none;
      background: linear-gradient(180deg, var(--bg1) 0%, var(--bg3) 100%);
      color: var(--ink2); cursor: pointer; font-size: 12px; font-family: var(--font);
      font-weight: 600; transition: transform .08s, box-shadow .08s; white-space: nowrap;
      box-shadow: 0 3px 0 var(--btn-depth-ghost), 0 4px 6px rgba(100,60,20,.12);
      outline: 1px solid var(--line);
    }
    .hbtn:hover { transform: translateY(-1px); box-shadow: 0 4px 0 var(--btn-depth-ghost), 0 6px 8px rgba(100,60,20,.15); color: var(--ink); }
    .hbtn.primary {
      background: linear-gradient(180deg,#e8a870 0%,var(--brand) 100%); color: #fff; outline: none;
      box-shadow: 0 3px 0 var(--btn-depth-brand), 0 4px 7px rgba(139,74,40,.25);
      text-shadow: 0 1px 2px rgba(0,0,0,.2);
    }
    .hbtn.primary:hover { box-shadow: 0 4px 0 var(--btn-depth-brand), 0 6px 10px rgba(139,74,40,.3); }
    .hbtn:active { transform: translateY(2px) !important; box-shadow: 0 1px 0 var(--btn-depth-ghost) !important; }
    .hbtn.primary:active { box-shadow: 0 1px 0 var(--btn-depth-brand) !important; }

    .hbtn-icon {
      width: 32px; height: 32px; padding: 0;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 14px; border-radius: var(--r);
      border: 1px solid var(--line); background: var(--bg2); color: var(--ink3);
      cursor: pointer; transition: all .15s;
    }
    .hbtn-icon:hover { background: var(--bg3); color: var(--ink); }

    kbd {
      display: inline-flex; padding: 1px 5px; border-radius: 4px;
      border: 1px solid var(--line2); background: var(--bg3);
      font-family: var(--mono); font-size: 10px; color: var(--ink3);
    }

    /* ══ BODY LAYOUT (Sidebar + Content) ═══════ */
    #body-wrap {
      flex: 1; overflow: hidden;
      display: flex;
    }

    /* ══ SIDEBAR ════════════════════════════════ */
    #sidebar {
      width: var(--sidebar-w); flex-shrink: 0;
      background: var(--bg1);
      border-right: 1px solid var(--line);
      display: flex; flex-direction: column;
      overflow: hidden;
      transition: width .25s cubic-bezier(.4,0,.2,1);
    }

    #sidebar.collapsed { width: var(--sidebar-collapsed-w); }

    .sidebar-section {
      padding: 8px 8px 0;
    }

    .sidebar-label {
      font-size: 10px; font-weight: 700;
      color: var(--ink4); letter-spacing: .7px;
      text-transform: uppercase;
      padding: 8px 8px 4px;
      white-space: nowrap; overflow: hidden;
    }

    .sidebar-item {
      display: flex; align-items: center; gap: 9px;
      padding: 7px 8px; border-radius: 8px;
      cursor: pointer; transition: all .15s;
      color: var(--ink3); font-size: 13px; font-weight: 500;
      white-space: nowrap; overflow: hidden;
      position: relative;
    }
    .sidebar-item:hover { background: var(--bg2); color: var(--ink); }
    .sidebar-item.active {
      background: var(--brand-light);
      color: var(--brand);
    }
    .sidebar-item.active .si-icon { color: var(--brand); }
    .si-icon { font-size: 14px; flex-shrink: 0; width: 18px; text-align: center; }
    .si-label { flex: 1; min-width: 0; }
    .si-badge {
      font-size: 10px; font-weight: 700; padding: 1px 5px;
      border-radius: 10px; background: var(--red-bg); color: var(--red);
      flex-shrink: 0;
    }

    .sidebar-sep { height: 1px; background: var(--line); margin: 6px 8px; }

    .sidebar-scroll {
      flex: 1; overflow-y: auto; overflow-x: hidden;
      padding-bottom: 12px;
    }
    .sidebar-scroll::-webkit-scrollbar { width: 3px; }
    .sidebar-scroll::-webkit-scrollbar-thumb { background: var(--line2); border-radius: 2px; }

    .sidebar-bottom {
      border-top: 1px solid var(--line);
      padding: 8px;
    }

    /* ══ MAIN CONTENT ═══════════════════════════ */
    #main-content {
      flex: 1; overflow: hidden;
      display: flex; flex-direction: column;
    }

    /* Homepage (no company selected) */
    #homepage {
      flex: 1; overflow-y: auto;
      display: flex; flex-direction: column;
    }
    #homepage.hidden { display: none; }
    #homepage::-webkit-scrollbar { width: 5px; }
    #homepage::-webkit-scrollbar-thumb { background: var(--line2); border-radius: 3px; }

    /* Workspace (company selected) */
    #workspace {
      display: none; flex-direction: column;
      height: 100%; overflow: hidden;
    }
    #workspace.active { display: flex; }

    /* Workspace topbar - compact */
    .ws-topbar {
      background: var(--bg1);
      border-bottom: 1px solid var(--line);
      display: flex; align-items: center;
      padding: 0 14px; height: 40px; flex-shrink: 0; gap: 8px;
      box-shadow: 0 1px 0 var(--line);
    }

    .ws-back {
      display: flex; align-items: center; gap: 5px;
      cursor: pointer; padding: 4px 8px; border-radius: var(--r);
      color: var(--ink3); font-size: 12px; font-weight: 500;
      border: 1px solid transparent; transition: all .15s;
    }
    .ws-back:hover { background: var(--bg3); border-color: var(--line); color: var(--ink); }

    .ws-co-badge {
      display: flex; align-items: center; gap: 8px;
    }
    .ws-co-av {
      width: 24px; height: 24px; border-radius: 6px;
      display: flex; align-items: center; justify-content: center; font-size: 11px; flex-shrink: 0;
    }
    .ws-co-nm { font-size: 13px; font-weight: 700; color: var(--ink); }
    .ws-co-cd { font-size: 11px; color: var(--ink3); font-family: var(--mono); }

    .ws-end { display: flex; align-items: center; gap: 6px; margin-left: auto; }

    /* Module tabs - scrollable */
    .ws-tabs {
      background: var(--bg1); border-bottom: 1px solid var(--line);
      display: flex; align-items: flex-end;
      padding: 0 16px; gap: 0;
      flex-shrink: 0; overflow-x: auto;
    }
    .ws-tabs::-webkit-scrollbar { height: 0; }

    .wt {
      display: flex; align-items: center; gap: 5px;
      padding: 10px 12px; font-size: 12.5px; font-weight: 500;
      color: var(--ink3); cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: all .15s; white-space: nowrap;
    }
    .wt:hover { color: var(--ink); }
    .wt.on { color: var(--brand); border-bottom-color: var(--brand); }
    .wt-sep { width: 1px; height: 14px; background: var(--line); margin: 0 4px 6px; flex-shrink: 0; }

    /* Workspace body */
    .ws-body {
      flex: 1; overflow-y: auto; padding: 18px 20px;
      animation: fadeUp .2s ease-out;
    }
    .ws-body::-webkit-scrollbar { width: 5px; }
    .ws-body::-webkit-scrollbar-thumb { background: var(--line2); border-radius: 3px; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ══ HOMEPAGE STYLES ════════════════════════ */
    .hp-wrap { padding: 24px; }

    .hp-hero {
      background: linear-gradient(135deg, #e8a870 0%, var(--brand) 50%, var(--brand-dark) 100%);
      border-radius: var(--r3);
      padding: 28px 32px;
      color: #fff;
      margin-bottom: 20px;
      position: relative;
      overflow: hidden;
    }
    .hp-hero::before {
      content: '';
      position: absolute; top: -40px; right: -40px;
      width: 200px; height: 200px;
      background: rgba(255,255,255,.06);
      border-radius: 50%;
    }
    .hp-hero::after {
      content: '';
      position: absolute; bottom: -60px; right: 100px;
      width: 150px; height: 150px;
      background: rgba(255,255,255,.04);
      border-radius: 50%;
    }
    .hp-hero-title {
      font-size: 22px; font-weight: 700; letter-spacing: -.5px;
      margin-bottom: 6px;
    }
    .hp-hero-sub { font-size: 13px; opacity: .8; }
    .hp-hero-stats {
      display: flex; gap: 24px; margin-top: 20px;
      position: relative; z-index: 1;
    }
    .hp-hero-stat { }
    .hp-hero-stat-v { font-size: 22px; font-weight: 700; font-family: var(--mono); }
    .hp-hero-stat-l { font-size: 11px; opacity: .75; margin-top: 1px; }

    .hp-section-hd {
      display: flex; align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .hp-section-title {
      font-size: 13px; font-weight: 700;
      color: var(--ink2); letter-spacing: .3px;
      display: flex; align-items: center; gap: 7px;
    }
    .hp-section-title::before {
      content: ''; display: block;
      width: 3px; height: 14px;
      background: var(--brand); border-radius: 2px;
    }

    /* KPI row */
    .kpi-grid {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 12px;
      margin-bottom: 20px;
    }
    .kpi-card {
      background: var(--bg1);
      border: 1px solid var(--line);
      border-radius: var(--r2);
      padding: 16px 18px;
      box-shadow: var(--shadow);
      position: relative; overflow: hidden;
    }
    .kpi-card::after {
      content: '';
      position: absolute; top: 0; left: 0; right: 0;
      height: 3px; border-radius: var(--r2) var(--r2) 0 0;
      background: var(--kpi-accent, var(--brand));
    }
    .kpi-icon { font-size: 18px; margin-bottom: 10px; }
    .kpi-label {
      font-size: 10px; font-weight: 700; color: var(--ink4);
      letter-spacing: .7px; text-transform: uppercase; margin-bottom: 4px;
    }
    .kpi-value {
      font-size: 22px; font-weight: 700; font-family: var(--mono);
      color: var(--ink); letter-spacing: -.5px;
    }
    .kpi-sub { font-size: 11px; color: var(--ink3); margin-top: 3px; }
    .kpi-sub.up { color: var(--green); }
    .kpi-sub.down { color: var(--red); }
    .kpi-sub.warn { color: var(--amber); }

    /* Company grid */
    .co-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
      gap: 14px;
    }

    /* Company card — redesigned */
    .co-card {
      background: var(--bg1);
      border: 1px solid var(--line);
      border-radius: var(--r2);
      cursor: pointer;
      transition: all .2s cubic-bezier(.4,0,.2,1);
      box-shadow: var(--shadow);
      overflow: hidden;
      display: flex; flex-direction: column;
    }
    .co-card:hover {
      border-color: var(--brand);
      box-shadow: var(--shadow-md), 0 0 0 3px var(--brand-glow);
      transform: translateY(-2px);
    }

    .co-card-header {
      padding: 16px 18px;
      display: flex; align-items: center; gap: 12px;
    }
    .co-avatar {
      width: 44px; height: 44px; border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
    }
    .co-info { flex: 1; min-width: 0; }
    .co-name {
      font-size: 14px; font-weight: 700; color: var(--ink);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .co-meta { display: flex; align-items: center; gap: 6px; margin-top: 3px; }
    .co-code { font-size: 11px; color: var(--ink3); font-family: var(--mono); }
    .co-type {
      font-size: 10px; font-weight: 700;
      padding: 1px 6px; border-radius: 10px;
      background: var(--brand-light); color: var(--brand);
    }

    .co-card-metrics {
      display: grid; grid-template-columns: repeat(3,1fr);
      border-top: 1px solid var(--line);
    }
    .co-metric {
      padding: 10px 16px;
      border-right: 1px solid var(--line);
    }
    .co-metric:last-child { border-right: none; }
    .co-metric-v { font-size: 12.5px; font-weight: 700; font-family: var(--mono); color: var(--ink); }
    .co-metric-l { font-size: 10px; color: var(--ink4); margin-top: 1px; }

    .co-card-footer {
      padding: 10px 18px;
      display: flex; align-items: center; justify-content: space-between;
      background: var(--bg2);
    }

    .status-pill {
      display: flex; align-items: center; gap: 4px;
      font-size: 11px; font-weight: 600;
      padding: 3px 8px; border-radius: 10px;
    }
    .sp-ok { background: var(--green-bg); color: var(--green); }
    .sp-warn { background: var(--amber-bg); color: var(--amber); }
    .sp-err { background: var(--red-bg); color: var(--red); }

    .open-btn {
      display: flex; align-items: center; gap: 4px;
      font-size: 12px; font-weight: 600; color: var(--brand);
      padding: 5px 12px; border-radius: var(--r);
      border: 1px solid var(--brand-light);
      background: var(--brand-light); cursor: pointer; transition: all .15s;
    }
    .co-card:hover .open-btn { background: var(--brand); color: #fff; border-color: var(--brand); }

    /* Add company card */
    .add-co-card {
      background: var(--bg2);
      border: 2px dashed var(--line2);
      border-radius: var(--r2);
      min-height: 180px;
      cursor: pointer; transition: all .2s;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      gap: 8px; color: var(--ink4);
    }
    .add-co-card:hover { border-color: var(--brand); color: var(--brand); background: var(--brand-light); }
    .add-co-icon {
      width: 42px; height: 42px; border-radius: 10px;
      border: 2px dashed currentColor;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; transition: all .2s;
    }
    .add-co-card:hover .add-co-icon { background: var(--brand); color: #fff; border-color: var(--brand); }
    .add-co-text { font-size: 13px; font-weight: 600; }
    .add-co-sub { font-size: 11px; color: var(--ink4); }

    /* ══ SHARED WORKSPACE UI ════════════════════ */
    .section-header {
      display: flex; align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .section-title {
      font-size: 14px; font-weight: 700; color: var(--ink);
      display: flex; align-items: center; gap: 7px;
    }
    .section-title small { font-size: 11px; color: var(--ink3); font-weight: 400; }

    /* Metric cards grid */
    .g3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 16px; }
    .g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
    .g4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-bottom: 16px; }

    /* Metric card */
    .mcard {
      background: var(--bg1); border: 1px solid var(--line);
      border-radius: var(--r2); padding: 14px 16px;
      box-shadow: var(--shadow);
    }
    .mcard-icon { font-size: 16px; margin-bottom: 8px; }
    .mcard-label { font-size: 10px; font-weight: 700; color: var(--ink4); letter-spacing: .6px; text-transform: uppercase; margin-bottom: 4px; }
    .mcard-val { font-size: 20px; font-weight: 700; font-family: var(--mono); color: var(--ink); }
    .mcard-sub { font-size: 11px; color: var(--ink3); margin-top: 3px; }
    .mcard-sub.g { color: var(--green); }
    .mcard-sub.r { color: var(--red); }
    .mcard-sub.a { color: var(--amber); }

    /* Card */
    .card {
      background: var(--bg1); border: 1px solid var(--line);
      border-radius: var(--r2); padding: 16px;
      box-shadow: var(--shadow);
    }
    .kcard { background: var(--bg1); border: 1px solid var(--line); border-radius: var(--r2); padding: 14px 16px; box-shadow: var(--shadow); }

    /* Table wrapper */
    .tw { background: var(--bg1); border: 1px solid var(--line); border-radius: var(--r2); overflow: hidden; box-shadow: var(--shadow); }

    table { width: 100%; border-collapse: collapse; }
    th {
      padding: 9px 13px; text-align: left;
      font-size: 10.5px; font-weight: 700; color: var(--ink3);
      letter-spacing: .6px; text-transform: uppercase;
      background: var(--bg2); border-bottom: 1px solid var(--line);
    }
    td {
      padding: 9px 13px; border-bottom: 1px solid var(--bg2);
      font-size: 13px; vertical-align: middle; color: var(--ink2);
