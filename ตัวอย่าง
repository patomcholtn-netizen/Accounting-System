function autoBackupToStorage() {
  if (!db || window._skipAutoBackup) return;
  try {
    const data = db.export();
    const arr = Array.from(data);
    localStorage.setItem("firmos_db", JSON.stringify(arr));
    const now = new Date();
    // ✅ เปลี่ยนจาก "firmos_bk_" + now.getFullYear() + "_" + ...
    const hk = `firmos_bk_${now.getFullYear()}_${String(now.getMonth()+1).padStart(2,"0")}_${String(now.getDate()).padStart(2,"0")}_${String(now.getHours()).padStart(2,"0")}`;
    localStorage.setItem(hk, JSON.stringify(arr));
    localStorage.setItem(`${hk}_ts`, Date.now().toString());
    localStorage.setItem("firmos_last_backup", now.toISOString());
    Object.keys(localStorage).filter(function(k){ return k.startsWith("firmos_bk_"); }).forEach(function(k) {
      const ts = localStorage.getItem(`${k}_ts`);
      if (ts && parseInt(ts) < Date.now() - (25*60*60*1000)) { 
        localStorage.removeItem(k); 
        localStorage.removeItem(`${k}_ts`); 
      }
    });
    showBackupBanner();
  } catch(e) { console.warn("backup failed", e); }
}

