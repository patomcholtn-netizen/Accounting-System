// ✅ เปลี่ยนจาก 'ปรับสต็อก '+(mtype)+' '+(qty)+''
function saveStockAdj() {
  const pid = parseInt(document.getElementById('sa-pid').value);
  const mtype = document.getElementById('sa-t').value;
  const qty = parseFloat(document.getElementById('sa-qty').value) || 0;
  const cost = parseFloat(document.getElementById('sa-cost').value) || 0;
  if (qty <= 0) return toast('จำนวนต้องมากกว่า 0', 'er');
  const prod = q('SELECT qty_on_hand,avg_cost FROM products WHERE id=? AND co_id=?', [pid, acId])[0];
  if (!prod) return;
  const wid = q1('SELECT id FROM warehouses WHERE co_id=? AND code=\'WH01\'', [acId]);
  const newQty = mtype === 'OUT' ? prod[0] - qty : prod[0] + qty;
  let newCost = prod[1];
  if (mtype === 'IN' && qty > 0) newCost = (prod[0] * prod[1] + qty * cost) / (prod[0] + qty);
  try {
    db.run('BEGIN');
    db.run('UPDATE products SET qty_on_hand=?,avg_cost=? WHERE id=? AND co_id=?', [newQty, newCost, pid, acId]);
    db.run('INSERT INTO stock_moves(co_id,product_id,warehouse_id,move_date,move_type,qty,unit_cost,qty_after,desc)VALUES(?,?,?,?,?,?,?,?,?)',
      [acId, pid, wid, document.getElementById('sa-dt').value, mtype, qty, cost, newQty, document.getElementById('sa-desc').value || '']);
    db.run('COMMIT');
    logAudit('UPDATE', 'products', String(pid), String(prod[0]), `ปรับสต็อก ${mtype} ${qty}`);
    closeMo(); 
    toast('✅ ปรับสต็อกแล้ว', 'ok'); 
    rInventory();
  } catch (e) { 
    db.run('ROLLBACK'); 
    toast(e.message, 'er'); 
  }
}

