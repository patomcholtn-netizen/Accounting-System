      th { background-color: #f0f0f0 !important; border-bottom: 2px solid #ccc !important; }
      td { border-bottom: 1px solid #eee !important; }
      tr { page-break-inside: avoid; }
      input, select, textarea { border: none !important; background: transparent !important; box-shadow: none !important; padding: 0 !important; appearance: none; -webkit-appearance: none; }
    }

    /* Period close UI */
    .period-row { display: flex; align-items: center; justify-content: space-between; padding: 8px 12px; border-radius: var(--r); border: 1px solid var(--line); margin-bottom: 6px; background: var(--bg1); }
    .pd-label { font-size: 13px; font-weight: 500; color: var(--ink); }
    .pd-stat { font-size: 11px; color: var(--ink3); }

