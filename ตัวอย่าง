function openEditOB() {
  const accounts = q("SELECT a.aid,a.name,a.type,a.norm,CASE WHEN a.norm='Debit' THEN COALESCE(SUM(l.dr),0)-COALESCE(SUM(l.cr),0) ELSE COALESCE(SUM(l.cr),0)-COALESCE(SUM(l.dr),0) END bal FROM accounts a LEFT JOIN jl l ON a.aid=l.aid AND a.co_id=l.co_id LEFT JOIN jh h ON l.doc=h.doc AND l.co_id=h.co_id AND h.status='Posted' WHERE a.co_id=? AND a.hdr=0 GROUP BY a.aid ORDER BY a.aid", [acId]);
  
  // ✅ ✅ ✅ แก้ syntax error ร้ายแรง - เปลี่ยนเป็น template literal ทั้งหมด
  const rows = accounts.map(function(r) {
    return `<tr>
      <td style="font-family:var(--mono);font-size:12px">${r[0]}</td>
      <td style="font-size:12px">${r[1]}</td>
      <td><span class="bx" style="font-size:10px">${r[2]}</span></td>
      <td><input type="number" step="0.01" value="${(r[4]||0).toFixed(2)}" data-aid="${r[0]}" data-norm="${r[3]}" style="width:110px;text-align:right;font-family:var(--mono);font-size:12px;padding:3px 6px;border:1px solid var(--line);border-radius:4px;background:var(--bg2);color:var(--ink)"></td>
    </tr>`;
  }).join("");
  
  showMo(`<div class="mo-t">✏️ แก้ไข Opening Balance</div>
    <div style="max-height:400px;overflow-y:auto">
      <table style="width:100%;border-collapse:collapse">
        <thead>
          <tr style="font-size:11px;color:var(--ink3);border-bottom:1px solid var(--line)">
            <th style="padding:4px;text-align:left">รหัส</th>
            <th style="padding:4px;text-align:left">ชื่อบัญชี</th>
            <th style="padding:4px;text-align:left">ประเภท</th>
            <th style="padding:4px;text-align:right">ยอด (฿)</th>
          </tr>
        </thead>
        <tbody>${rows}</tbody>
      </table>
    </div>
    <div class="mo-f">
      <button class="btn" onclick="closeMo()">ยกเลิก</button>
      <button class="btn btn-p" onclick="saveOB()">✅ บันทึก</button>
    </div>`);
}

// ✅ เปลี่ยนจาก "✅ บันทึก Opening Balance " + adj.length + " รายการ"
function saveOB() {
  const inputs = document.querySelectorAll("[data-aid]");
  const adj = [];
  inputs.forEach(function(inp) {
    const aid = inp.dataset.aid, norm = inp.dataset.norm;
    const newBal = parseFloat(inp.value) || 0;
    const cur = q1("SELECT CASE WHEN a.norm='Debit' THEN COALESCE(SUM(l.dr),0)-COALESCE(SUM(l.cr),0) ELSE COALESCE(SUM(l.cr),0)-COALESCE(SUM(l.dr),0) END FROM accounts a LEFT JOIN jl l ON a.aid=l.aid AND a.co_id=l.co_id LEFT JOIN jh h ON l.doc=h.doc AND l.co_id=h.co_id AND h.status='Posted' WHERE a.aid=? AND a.co_id=?", [aid, acId]) || 0;
    const diff = newBal - cur;
    if (Math.abs(diff) >= 0.01) adj.push([aid, norm, diff]);
  });
  if (!adj.length) { 
    closeMo(); 
    return toast("ไม่มียอดที่เปลี่ยนแปลง", "ok"); 
  }
  _postOBAdjJV(adj);
  closeMo();
  toast(`✅ บันทึก Opening Balance ${adj.length} รายการ`, "ok");
  rBS();
}

function _postOBAdjJV(adj) {
  const doc = genDoc(acId, "OB");
  const dt  = new Date().toISOString().split("T")[0];
  const now = new Date(), mon = now.getMonth()+1, yr = now.getFullYear();
  db.run("INSERT OR REPLACE INTO jh(doc,co_id,dt,dty,desc,status,mon,yr) VALUES(?,?,?,?,?,?,?,?)",
    [doc, acId, dt, "General", "ปรับยอด Opening Balance", "Posted", mon, yr]);
  let seq = 1;
  adj.forEach(function(item) {
    const aid = item[0], norm = item[1], diff = item[2];
    const dr = ((norm==="Debit" && diff>0)||(norm==="Credit" && diff<0)) ? Math.abs(diff) : 0;
    const cr = ((norm==="Credit" && diff>0)||(norm==="Debit" && diff<0)) ? Math.abs(diff) : 0;
    db.run("INSERT INTO jl(doc,co_id,seq,aid,desc,dr,cr) VALUES(?,?,?,?,?,?,?)",
      [doc, acId, seq++, aid, "ปรับยอด OB", dr, cr]);
  });
}
