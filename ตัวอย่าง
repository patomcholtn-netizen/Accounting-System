// ── AGING REPORT ─────────────────────────────────────────────
function rAging() {
  if (!acId) return;
  const td = today();
  const rows = q('SELECT a.*,c.name,c.code,c.credit_days FROM ar_ap a LEFT JOIN contacts c ON a.contact_id=c.id WHERE a.co_id=? AND a.status IN(\'Open\',\'PartPaid\') ORDER BY a.due_date', [acId]);

  let buckets = { c0: 0, c30: 0, c60: 0, c90: 0, cOver: 0 };
  const mapped = rows.map(([id, coid, ctId, docNo, dtype, docDate, dueDate, amount, paid, status, ref, desc, ctName, ctCode, creditDays]) => {
    const balance = amount - paid;
    const days = Math.floor((new Date(td) - new Date(dueDate)) / (864e5));
    let bucket = 'current';
    if (days > 90) { bucket = '>90'; buckets.cOver += balance; }
    else if (days > 60) { bucket = '61-90'; buckets.c90 += balance; }
    else if (days > 30) { bucket = '31-60'; buckets.c60 += balance; }
    else if (days > 0) { bucket = '1-30'; buckets.c30 += balance; }
    else { bucket = 'ยังไม่ถึง'; buckets.c0 += balance; }
    return { docNo, docDate, dueDate, ctName, ctCode, amount, paid, balance, days, bucket, dtype };
  });

  const total = Object.values(buckets).reduce((s, v) => s + v, 0);

  setWS(`
    <div class="sh"><div class="sh-t">รายงานอายุหนี้ (Aging Report)</div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-sm btn-g" onclick="xlsxAging()">📊 Excel</button>
        <button class="btn btn-sm" onclick="window.print()">🖨 Print</button>
      </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:18px">
      ${[['ยังไม่ถึงกำหนด', buckets.c0, 'var(--green)'], ['1-30 วัน', buckets.c30, 'var(--a)'], ['31-60 วัน', buckets.c60, 'var(--amber)'], ['61-90 วัน', buckets.c90, 'var(--red)'], ['> 90 วัน', buckets.cOver, '#8b0000']].map(([l, v, col]) => `
      <div class="kcard" style="border-top:3px solid ${col}">
        <div class="kpi-l">${l}</div>
        <div class="kpi-v" style="color:${col};font-size:16px">฿${fmtK(v)}</div>
        <div class="kpi-s">${total > 0 ? ((v / total) * 100).toFixed(1) : 0}%</div>
      </div>`).join('')}
    </div>
    <div class="tw"><table><thead><tr>
      <th>เลขที่</th><th>คู่ค้า</th><th>ประเภท</th><th>วันที่เอกสาร</th><th>วันที่ครบกำหนด</th>
      <th class="n">ยอดรวม</th><th class="n">ชำระแล้ว</th><th class="n">คงเหลือ</th><th>อายุ</th><th>สถานะ</th>
    </tr></thead><tbody>
    ${mapped.map(r => `<tr>
      <td class="code">${r.docNo}</td>
      <td style="font-weight:500">${r.ctName || '-'}</td>
      <td><span class="bx ${r.dtype === 'AR' ? 'bg' : 'ba'}">${r.dtype}</span></td>
      <td style="font-size:11px;color:var(--ink3)">${r.docDate}</td>
      <td style="font-size:11px;color:var(--ink3)">${r.dueDate}</td>
      <td class="n">฿${fmt(r.amount)}</td>
      <td class="n" style="color:var(--green)">฿${fmt(r.paid)}</td>
      <td class="n" style="font-weight:600;color:${r.balance > 0 ? 'var(--red)' : 'var(--green)'}">฿${fmt(r.balance)}</td>
      <td><span class="bx ${r.days > 90 ? 'br' : r.days > 60 ? 'ba' : r.days > 30 ? 'ba' : 'bg'}">${r.days > 0 ? `${r.days} วัน` : 'ยังไม่ถึง'}</span></td>
      <td><span class="bx ${r.bucket === '>90' ? 'br' : r.bucket === '61-90' ? 'br' : r.bucket === '31-60' ? 'ba' : r.bucket === '1-30' ? 'bb' : 'bg'}">${r.bucket}</span></td>
    </tr>`).join('')}
    </tbody></table></div>`);
}

